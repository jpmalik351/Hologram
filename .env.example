# Core AI services

#OPENAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=onyx

#PINECONE
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=hologram-conversations
PINECONE_REGION=us-east-1 #us-east-1 is the default region


#=====================

# Auth + session security
# Required by current backend login flow in all environments unless auth code is replaced.
AUTH_CREDENTIALS=admin:change_me
FLASK_SECRET_KEY=replace_with_a_long_random_secret
FLASK_ENV=development

#=====================
# Database
# Use PostgreSQL in production (Render injects this automatically from render.yaml).
# Local fallback to SQLite is currently supported for quick local testing.
DATABASE_URL=postgresql://user:password@host:5432/hologram